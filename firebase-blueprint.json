{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with role and branch association",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "roleId": { "type": "string" },
        "branchId": { "type": "string" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "name", "email", "roleId", "branchId", "isActive"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "Product in stock",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "barcode": { "type": "string" },
        "quantity": { "type": "number" },
        "threshold": { "type": "number" },
        "purchasePrice": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "gstPercent": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["in-stock", "low-stock", "out-of-stock", "expiring-soon"] },
        "branchId": { "type": "string" }
      },
      "required": ["id", "name", "sku", "quantity", "threshold", "purchasePrice", "sellingPrice", "gstPercent", "status", "branchId"]
    },
    "Order": {
      "title": "Order",
      "description": "Sales transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "customerId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["PAID", "PARTIALLY_PAID", "UNPAID"] },
        "branchId": { "type": "string" }
      },
      "required": ["id", "date", "items", "totalAmount", "paymentStatus", "branchId"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Retail customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "totalSpent": { "type": "number" },
        "loyaltyPoints": { "type": "number" }
      },
      "required": ["id", "name", "phone"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "branchId": { "type": "string" },
        "status": { "type": "string", "enum": ["paid", "pending", "upcoming"] }
      },
      "required": ["id", "title", "amount", "category", "date", "branchId", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/inventory/{itemId}": {
      "schema": "InventoryItem",
      "description": "Inventory items"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Sales orders"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customer records"
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Business expenses"
    }
  }
}
