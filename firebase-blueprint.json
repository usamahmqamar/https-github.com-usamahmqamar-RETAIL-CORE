{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with role and branch association",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "roleId": { "type": "string" },
        "branchId": { "type": "string" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "name", "email", "roleId", "branchId", "isActive"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "Product in stock",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "barcode": { "type": "string" },
        "quantity": { "type": "number" },
        "threshold": { "type": "number" },
        "purchasePrice": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "gstPercent": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["in-stock", "low-stock", "out-of-stock", "expiring-soon"] },
        "branchId": { "type": "string" }
      },
      "required": ["id", "name", "sku", "quantity", "threshold", "purchasePrice", "sellingPrice", "gstPercent", "status", "branchId"]
    },
    "Order": {
      "title": "Order",
      "description": "Sales transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "customerId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["PAID", "PARTIALLY_PAID", "UNPAID"] },
        "branchId": { "type": "string" }
      },
      "required": ["id", "date", "items", "totalAmount", "paymentStatus", "branchId"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Retail customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "totalSpent": { "type": "number" },
        "loyaltyPoints": { "type": "number" }
      },
      "required": ["id", "name", "phone"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "branchId": { "type": "string" },
        "status": { "type": "string", "enum": ["paid", "pending", "upcoming"] }
      },
      "required": ["id", "title", "amount", "category", "date", "branchId", "status"]
    },
    "VendorBill": {
      "title": "Vendor Bill",
      "description": "Invoice received from a vendor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vendorId": { "type": "string" },
        "billNumber": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "dueDate": { "type": "string", "format": "date" },
        "totalAmount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "balance": { "type": "number" },
        "status": { "type": "string", "enum": ["PAID", "PARTIALLY_PAID", "UNPAID"] },
        "branchId": { "type": "string" }
      },
      "required": ["id", "vendorId", "billNumber", "date", "dueDate", "totalAmount", "paidAmount", "balance", "status", "branchId"]
    },
    "VendorPayment": {
      "title": "Vendor Payment",
      "description": "Payment made to a vendor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "billId": { "type": "string" },
        "vendorId": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "paymentMethod": { "type": "string", "enum": ["CASH", "BANK_TRANSFER", "CHEQUE", "UPI"] }
      },
      "required": ["id", "billId", "vendorId", "amount", "date", "paymentMethod"]
    },
    "PromoCode": {
      "title": "Promo Code",
      "description": "Discount coupon for the storefront",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "type": { "type": "string", "enum": ["PERCENT", "FIXED"] },
        "value": { "type": "number" },
        "minOrderAmount": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date" },
        "isActive": { "type": "boolean" },
        "usageLimit": { "type": "number" },
        "usageCount": { "type": "number" }
      },
      "required": ["id", "code", "type", "value", "minOrderAmount", "expiryDate", "isActive", "usageCount"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Inventory vendor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "contactPerson": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "gstNumber": { "type": "string" },
        "paymentTerms": { "type": "string" },
        "totalOwed": { "type": "number" },
        "totalPaid": { "type": "number" }
      },
      "required": ["id", "name", "totalOwed", "totalPaid"]
    },
    "PurchaseOrder": {
      "title": "Purchase Order",
      "description": "Order sent to a supplier",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["DRAFT", "SENT", "RECEIVED", "CANCELLED"] },
        "receivedDate": { "type": "string" },
        "branchId": { "type": "string" }
      },
      "required": ["id", "supplierId", "date", "items", "totalAmount", "status", "branchId"]
    },
    "StockLog": {
      "title": "Stock Log",
      "description": "Historical record of stock movement",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "barcode": { "type": "string" },
        "quantityAdded": { "type": "number" },
        "purchasePrice": { "type": "number" },
        "actionType": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "branchId": { "type": "string" },
        "supplierId": { "type": "string" },
        "billNumber": { "type": "string" }
      },
      "required": ["id", "productId", "quantityAdded", "actionType", "date", "branchId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/inventory/{itemId}": {
      "schema": "InventoryItem",
      "description": "Inventory items"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Sales orders"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customer records"
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Business expenses"
    },
    "/vendor_bills/{billId}": {
      "schema": "VendorBill",
      "description": "Invoices from vendors"
    },
    "/vendor_payments/{paymentId}": {
      "schema": "VendorPayment",
      "description": "Payments to vendors"
    },
    "/promo_codes/{promoId}": {
      "schema": "PromoCode",
      "description": "Promotional discount codes"
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "External vendors"
    },
    "/purchase_orders/{poId}": {
      "schema": "PurchaseOrder",
      "description": "Inventory procurement"
    },
    "/stock_logs/{logId}": {
      "schema": "StockLog",
      "description": "Historical stock entries"
    }
  }
}
