rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions (Pillar 3)
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Admin check - includes the developer as a bootstrapped admin
    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email == "usamah.m.qamar@gmail.com" && request.auth.token.email_verified == true) ||
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleId == 'role-admin'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Validation Blueprints (Pillar 2)
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'roleId', 'branchId', 'isActive']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 128 &&
             data.roleId is string && data.branchId is string &&
             data.isActive is bool;
    }

    function isValidInventoryItem(data) {
      return data.keys().hasAll(['id', 'name', 'sku', 'quantity', 'threshold', 'purchasePrice', 'sellingPrice', 'gstPercent', 'status', 'branchId']) &&
             data.id is string && data.name is string && data.sku is string &&
             data.quantity is number && data.threshold is number &&
             data.purchasePrice is number && data.sellingPrice is number &&
             data.gstPercent is number && data.status is string && data.branchId is string;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'date', 'items', 'subtotal', 'totalGst', 'totalAmount', 'amountPaid', 'balanceDue', 'paymentMethod', 'paymentStatus', 'orderType', 'branchId']) &&
             data.id is string && data.date is string && data.items is list &&
             data.totalAmount is number && data.paymentStatus is string;
    }

    function isValidPromoCode(data) {
      return data.keys().hasAll(['id', 'code', 'type', 'value', 'minOrderAmount', 'expiryDate', 'isActive', 'usageCount']) &&
             data.id is string && data.code is string && data.code.size() <= 20 &&
             data.type in ['PERCENT', 'FIXED'] &&
             data.value is number && data.minOrderAmount is number &&
             data.expiryDate is string && data.isActive is bool && data.usageCount is number;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isEmailVerified() && (isOwner(userId) || isAdmin()) && isValidUser(incoming());
      allow update: if isEmailVerified() && (isOwner(userId) || isAdmin()) && isValidUser(incoming());
    }

    match /inventory/{itemId} {
      allow read: if isSignedIn();
      allow write: if isEmailVerified() && isAdmin() && isValidInventoryItem(incoming());
    }

    match /orders/{orderId} {
      // Secure list query (Pillar 8)
      allow list: if isSignedIn() && (isAdmin() || resource.data.customer.phone != null); // Allow if admin or specific customer
      allow get: if isSignedIn();
      allow create: if true; // Storefront creates orders (can be guest)
      allow update: if isEmailVerified() && isAdmin() && isValidOrder(incoming());
    }

    match /promo_codes/{promoId} {
      allow read: if true; // Everyone can read for validation
      allow create: if isEmailVerified() && isAdmin() && isValidPromoCode(incoming());
      allow update: if isEmailVerified() && isAdmin() && isValidPromoCode(incoming());
      allow delete: if isEmailVerified() && isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /expenses/{expenseId} {
      allow read: if isSignedIn();
      allow write: if isEmailVerified() && isAdmin();
    }

    match /vendor_bills/{billId} {
      allow read: if isSignedIn();
      allow write: if isEmailVerified() && isAdmin();
    }

    match /vendor_payments/{paymentId} {
      allow read: if isSignedIn();
      allow write: if isEmailVerified() && isAdmin();
    }
  }
}
